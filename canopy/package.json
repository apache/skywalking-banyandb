{
  "name": "canopy",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.6.0"
  },
  "workspaces": [
    "web",
    "server",
    "shared"
  ],
  "scripts": {
    "dev:web": "npm run -w web dev",
    "dev:server": "npm run -w server dev",
    "build": "npm run -w shared build && npm run -w web build && npm run -w server build",
    "build:web": "npm run -w web build",
    "test": "npm run -w web test && npm run -w server test",
    "lint": "npm run -w web lint && npm run -w server lint",
    "pree2e": "npm run build",
    "e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "e2e:vrt": "npx playwright test --config=e2e/playwright.config.ts --grep @vrt",
    "pree2e:update-baselines": "npm run build",
    "e2e:update-baselines": "npx playwright test --config=e2e/playwright.config.ts --grep @vrt --update-snapshots",
    "typecheck": "npm run -w shared typecheck && npm run -w web typecheck && npm run -w server typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/dom": "^10.4.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.2",
    "@vitest/coverage-v8": "^4.1.9"
  }
}
