# BanyanDB connection (HTTP grpc-gateway, NOT :17912 gRPC)
BANYANDB_TARGET=http://127.0.0.1:17913

# Prometheus/metrics monitoring target
MONITOR_TARGET=http://127.0.0.1:2121

# Canopy BFF server port
PORT=4000

# REQUIRED: random secret for session cookie encryption (min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# REQUIRED: path to a JSON/YAML file listing Canopy users
# Format: [{"username":"admin","passwordHash":"<bcrypt/argon2 hash>","role":"admin"}]
# Roles: admin (read-write) | readonly
CANOPY_USERS=./users.yaml

# Optional: BanyanDB upstream service credential (attach-if-configured)
# If set, this Basic-Auth credential is attached to EVERY proxied /api/* request.
# Auth-disabled BanyanDB clusters ignore it harmlessly.
BANYANDB_UPSTREAM_USERNAME=
BANYANDB_UPSTREAM_PASSWORD=
# Alternative: read password from a file (takes precedence over BANYANDB_UPSTREAM_PASSWORD)
BANYANDB_UPSTREAM_PASSWORD_FILE=

# Dev only: skip CANOPY_USERS requirement (seeds admin/admin). NEVER use in production.
# Boot FAILS if CANOPY_DEV_NOAUTH=true and NODE_ENV=production.
CANOPY_DEV_NOAUTH=false

# Upstream request timeout in milliseconds (default: 120000 = 2 minutes)
UPSTREAM_TIMEOUT_MS=120000
